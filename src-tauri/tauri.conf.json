{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri-docs/refs/heads/v2/docs/.vitepress/theme/schemas/config.schema.json",
  "productName": "Bangumini",
  "version": "0.1.0",
  "identifier": "com.bangumini.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bangumini",
        "width": 960,
        "height": 640,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
