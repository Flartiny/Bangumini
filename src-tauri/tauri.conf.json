{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri-docs/refs/heads/v2/docs/.vitepress/theme/schemas/config.schema.json",
  "productName": "Bangumini",
  "version": "1.1.10",
  "identifier": "com.bangumini.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bangumini",
        "width": 960,
        "height": 640,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/covers/**"]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGMDVDODIxRjczRDJFRkMKUldUOExqMzNJY2dGZnp1ZUZMbG9HZFR3Z0tYZE9mYmxSQXhiWXMzUldRRE81SVIzS3JrZ01kUGkK",
      "endpoints": [
        "https://github.com/Flartiny/Bangumini/releases/latest/download/latest.json"
      ]
    }
  }
}
